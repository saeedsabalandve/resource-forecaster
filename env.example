# # Environment Configuration Template
# # Copy this file to .env and customize for your environment

# # Server Configuration
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=30s
SERVER_MAX_REQUEST_BODY=1048576
SERVER_CORS_ORIGINS=https://dashboard.company.com,https://monitoring.internal

# # TimescaleDB Configuration
TSDB_HOST=localhost
TSDB_PORT=5432
TSDB_DATABASE=resource_forecaster
TSDB_USERNAME=forecaster
TSDB_PASSWORD=change_me_in_production
TSDB_MAX_CONNECTIONS=100
TSDB_MIN_CONNECTIONS=10
TSDB_MAX_CONN_LIFETIME=1h
TSDB_SSL_MODE=require
TSDB_RETENTION_DAYS=90

# # Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10

# # S3/MinIO Configuration
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=models
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true

# # Telemetry Configuration
TELEMETRY_METRICS_PORT=9090
TELEMETRY_TRACING_ENDPOINT=https://otel-collector.internal:4317
TELEMETRY_TRACING_SAMPLE_RATE=0.1
TELEMETRY_LOG_LEVEL=info
TELEMETRY_SERVICE_NAME=resource-forecaster
TELEMETRY_ENVIRONMENT=production

# # Scheduler Configuration
SCHEDULER_COLLECTION_INTERVAL=60s
SCHEDULER_TRAINING_INTERVAL=6h
SCHEDULER_EVALUATION_INTERVAL=24h
SCHEDULER_FORECAST_HORIZON_HOURS=168
SCHEDULER_RETENTION_PERIOD_DAYS=365

# # Authentication Configuration
AUTH_JWT_SECRET=your-512-bit-secret-key-here
AUTH_JWT_EXPIRATION=24h
AUTH_API_KEY_HEADER=X-API-Key
AUTH_INTERNAL_API_KEYS=key1,key2,key3
AUTH_OAUTH2_ISSUER_URL=https://auth.company.com

# # Cloud Provider Configuration
CLOUD_PROVIDER=aws
CLOUD_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# # Forecaster Configuration
FORECASTER_MODEL_BUCKET=models
FORECASTER_MIN_DATA_POINTS=168
FORECASTER_CONFIDENCE_INTERVAL=0.95
FORECASTER_ENSEMBLE_WEIGHTS_UPDATE=true
FORECASTER_GPU_ENABLED=false

# # Rate Limiting
RATE_LIMIT_GLOBAL_RPS=1000
RATE_LIMIT_PER_USER_RPS=100
RATE_LIMIT_PER_IP_RPS=50
RATE_LIMIT_LOCAL_BURST=20

# # Kubernetes specific
KUBERNETES_POD_NAME=
KUBERNETES_NAMESPACE=
KUBERNETES_NODE_NAME=
